PORT=3000

# Optional defaults for upstream LLM API
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TAB_MODEL=gpt-4o-mini
LLM_CHAPTER_MODEL=gpt-4.1-mini

# Tab completion behavior
LLM_MAX_TOKENS=80
LLM_TEMPERATURE=0.8
CONTEXT_CHARS=3000

# Full chapter continuation behavior
LLM_CHAPTER_MAX_TOKENS=1600
LLM_CHAPTER_TEMPERATURE=0.9
